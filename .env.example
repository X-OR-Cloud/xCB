# ============================================================
# xHR – AI-native HR Platform | Thinh Long Group
# ============================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://xhr_user:xhr_password@db:5432/xhr_db
DATABASE_SYNC_URL=postgresql://xhr_user:xhr_password@db:5432/xhr_db

# --- Anthropic / Claude ---
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-3-5-sonnet-20241022
CLAUDE_HAIKU_MODEL=claude-3-haiku-20240307

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=123456789:ABCDefGHIjklmNOPQRsTUVwxyz
TELEGRAM_WEBHOOK_SECRET=your-strong-random-secret-here

# --- App ---
APP_ENV=development   # development | production
APP_HOST=0.0.0.0
APP_PORT=8000

# --- X-OR CLOUD (CEPH / S3) ---
XOR_ACCESS_KEY=your_access_key
XOR_SECRET_KEY=your_secret_key
XOR_ENDPOINT_URL=https://s3.x-or.cloud
XOR_BUCKET_NAME=xhr-docs

# --- Qdrant ---
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=your_optional_qdrant_key

# --- Qwen Inference (Vision & Embedding) ---
QWEN_API_BASE=https://api.yourbase.com/v1
QWEN_API_KEY=your_qwen_api_key
QWEN_VL_MODEL=Qwen/Qwen2.5-VL-72B-Instruct
QWEN_EMBED_MODEL=Qwen/Qwen3-Embedding-8B

# --- Email / SMTP ---
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=xhr-noreply@thinhlonggroup.com

# --- PgAdmin (for docker-compose only) ---
PGADMIN_DEFAULT_EMAIL=admin@thinhlong.vn
PGADMIN_DEFAULT_PASSWORD=admin123
